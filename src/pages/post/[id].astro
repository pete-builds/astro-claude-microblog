---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { truncateTitle } from '../../utils/formatDate';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  return allPosts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const title = truncateTitle(post.data.text);
---

<BaseLayout title={`${title} | The Stack`} description={post.data.text.slice(0, 160)}>
  <div class="feed-container">
    <header class="post-page-header">
      <a href="/" class="back-link">&larr; The Stack</a>
    </header>

    <PostCard post={post} showShareButton={false} />

    <footer class="feed-footer">
      <p>&copy; {new Date().getFullYear()} Your Name</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .feed-container { max-width: 640px; margin: 0 auto; padding: 2rem 1rem; }
  .post-page-header { margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color); }
  .back-link { font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
  .back-link:hover { color: var(--orange); }
  .feed-footer { padding-top: 2rem; margin-top: 1rem; border-top: 1px solid var(--border-color); text-align: center; }
  .feed-footer p { font-size: 0.8rem; color: var(--text-muted); }
</style>
