---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { slugifyTag } from '../../utils/formatDate';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('posts');
  const sorted = allPosts.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );

  const tagCounts: Record<string, number> = {};
  allPosts.forEach((post) => {
    post.data.tags?.forEach((tag: string) => {
      tagCounts[tag] = (tagCounts[tag] || 0) + 1;
    });
  });
  const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);

  return paginate(sorted, {
    pageSize: 10,
    props: { sortedTags },
  });
}) satisfies GetStaticPaths;

const { page, sortedTags } = Astro.props;
const posts = page.data;
---

<BaseLayout>
  <div class="feed-container">
    <header class="feed-header">
      <h1 class="feed-title">Build Log</h1>
      <p class="feed-subtitle">What I'm shipping, learning, and figuring out. Published from the terminal.</p>
      <div class="header-tags">
        {sortedTags.slice(0, 10).map(([tag, count]) => (
          <a href={`/tag/${slugifyTag(tag)}/`} class="header-tag">{tag} <span class="tag-count">{count}</span></a>
        ))}
      </div>
    </header>

    <div class="feed">
      {posts.map((post) => {
        const isPinned = post.data.tags?.includes('Pinned');
        return (
          <PostCard post={post} isPinned={isPinned} siteUrl={Astro.site?.toString() || ''} />
        );
      })}
    </div>

    {page.lastPage > 1 && (
      <nav class="pagination" aria-label="Pagination">
        {page.url.prev ? (
          <a href={page.url.prev} class="page-link">&larr; Newer</a>
        ) : (
          <span class="page-link disabled">&larr; Newer</span>
        )}
        <span class="page-info">{page.currentPage} / {page.lastPage}</span>
        {page.url.next ? (
          <a href={page.url.next} class="page-link">Older &rarr;</a>
        ) : (
          <span class="page-link disabled">Older &rarr;</span>
        )}
      </nav>
    )}

    <footer class="feed-footer">
      <p>&copy; {new Date().getFullYear()} Your Name</p>
    </footer>
  </div>
  <script>
    document.querySelectorAll('.share-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const url = (btn as HTMLElement).dataset.url;
        if (url) {
          try {
            await navigator.clipboard.writeText(url);
            const el = btn as HTMLElement;
            el.style.color = 'var(--orange)';
            setTimeout(() => { el.style.color = ''; }, 1500);
          } catch {
            // Clipboard API not available
          }
        }
      });
    });

    document.querySelectorAll('.expand-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const postBody = btn.closest('.post-body');
        if (postBody) {
          postBody.classList.toggle('post-truncated');
          (btn as HTMLElement).textContent = postBody.classList.contains('post-truncated') ? 'Show more' : 'Show less';
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .feed-container { max-width: 640px; margin: 0 auto; padding: 2rem 1rem; }
  .feed-header { padding-bottom: 1.25rem; border-bottom: 1px solid var(--border-color); margin-bottom: 0.5rem; }

  .feed-title {
    font-size: 1.75rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--orange), var(--blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-align: center;
    padding-top: 1rem;
  }

  .feed-subtitle {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
    margin-top: 0.25rem;
    margin-bottom: 0.75rem;
  }

  .header-tags { margin-top: 1rem; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .header-tag { font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 4px; background: rgba(26, 111, 181, 0.08); color: var(--text-muted); font-weight: 500; text-decoration: none; transition: all 0.2s; }
  .header-tag:hover { background: rgba(26, 111, 181, 0.2); color: var(--blue-light); }
  .tag-count { color: var(--blue-light); font-weight: 700; }

  .pagination { display: flex; justify-content: center; align-items: center; gap: 1.5rem; padding: 1.5rem 0; margin-top: 1rem; border-top: 1px solid var(--border-color); }
  .page-link { font-size: 0.85rem; font-weight: 600; text-decoration: none; color: var(--blue-light); transition: color 0.2s; }
  .page-link:hover { color: var(--orange); }
  .page-link.disabled { color: var(--text-muted); opacity: 0.4; }
  .page-info { font-size: 0.8rem; color: var(--text-muted); font-weight: 600; }

  .feed-footer { padding-top: 2rem; margin-top: 1rem; border-top: 1px solid var(--border-color); text-align: center; }
  .feed-footer p { font-size: 0.8rem; color: var(--text-muted); }

  @media (max-width: 480px) {
    .feed-container { padding: 1rem 0.75rem; }
  }
</style>
