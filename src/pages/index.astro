---
import BaseLayout from '../layouts/BaseLayout.astro';

// Replace with your own projects, tools, and techniques
const featuredProject = {
  name: 'Your Featured Project',
  desc: 'A brief description of your most impressive open-source project. What it does, how it works, and why it matters.',
  tech: ['Python', 'Docker', 'SQLite'],
  url: 'https://github.com/your-username/your-project',
};

const projects = [
  {
    name: 'Project Two',
    desc: 'Another project you want to highlight.',
    tech: ['Python', 'Docker'],
  },
  {
    name: 'Project Three',
    desc: 'A third project to round out the grid.',
    tech: ['Go', 'Docker'],
  },
  {
    name: 'Project Four',
    desc: 'Keep the grid symmetrical with a fourth card.',
    tech: ['TypeScript', 'Node.js'],
  },
  {
    name: 'Project Five',
    desc: 'Or remove cards to fit your actual portfolio.',
    tech: ['Bash', 'Linux'],
  },
];

const apps = [
  {
    name: 'App One',
    desc: 'A self-hosted application you built and deployed.',
    tech: ['Python', 'FastAPI', 'Docker'],
    url: 'https://github.com/your-username/app-one',
  },
  {
    name: 'The Stack',
    desc: 'This site. Astro microblog, one-command publish from the terminal. No CMS, no database.',
    tech: ['Astro', 'Markdown', 'rsync'],
    url: 'https://github.com/your-username/astro-claude-microblog',
  },
];

const agentGroups = [
  {
    label: 'Operations',
    color: 'var(--blue)',
    agents: [
      { name: 'Agent One', role: 'Describe what this agent handles and its domain.' },
      { name: 'Agent Two', role: 'Another specialized agent with its own responsibilities.' },
    ],
  },
  {
    label: 'Development',
    color: 'var(--orange)',
    agents: [
      { name: 'Agent Three', role: 'A development-focused agent.' },
      { name: 'Agent Four', role: 'Another agent in this category.' },
    ],
  },
];

const techniques = [
  {
    title: 'Your First Technique',
    desc: 'Describe a pattern, approach, or methodology you use in your work.',
    post: '/post/003-how-this-works/',
  },
  {
    title: 'Your Second Technique',
    desc: 'Another technique or approach worth highlighting.',
  },
];
---

<BaseLayout title="CV | Your Name" description="How I use Claude Code: agents, tools, and infrastructure from one terminal.">
  <div class="lab-container">

    <!-- Hero -->
    <header class="lab-hero">
      <h1 class="lab-title">How I Work</h1>
      <p class="lab-tagline"><img src="/images/avatar.svg" alt="Your Name" class="lab-avatar" /> Your Name — Your Title</p>
      <div class="lab-links">
        <a href="https://github.com/your-username" target="_blank" rel="noopener" class="lab-social" title="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          your-username
        </a>
        <a href="https://linkedin.com/in/your-profile" target="_blank" rel="noopener" class="lab-social" title="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          Your Name
        </a>
      </div>
      <div class="lab-divider"></div>
      <div class="lab-intro">
        <p>Claude Code is my office suite. It's where I write code, manage servers, deploy websites, and publish this site. Not through chat conversations, but through a system of specialized agents, custom tools, and infrastructure that all connect through one terminal.</p>
        <p>Everything on this page is real, running in production, and used daily. <a href="/feed/" class="intro-link">Follow the build log &rarr;</a></p>
      </div>
    </header>

    <!-- Projects -->
    <section class="lab-section">
      <h2 class="section-heading">Open Source Projects</h2>
      <p class="section-desc">Tools and servers you've built and shared.</p>

      <!-- Featured -->
      <div class="card card-featured">
        <div class="card-header">
          <h3 class="card-title">{featuredProject.name}</h3>
          <a href={featuredProject.url} target="_blank" rel="noopener" class="card-gh" title="GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
        <p class="card-desc">{featuredProject.desc}</p>
        <div class="card-tech">
          {featuredProject.tech.map((t) => (
            <span class="tech-badge">{t}</span>
          ))}
        </div>
      </div>

      <!-- Grid -->
      <div class="card-grid">
        {projects.map((s) => (
          <div class="card">
            <div class="card-header">
              <h3 class="card-title">{s.name}</h3>
            </div>
            <p class="card-desc">{s.desc}</p>
            <div class="card-tech">
              {s.tech.map((t) => (
                <span class="tech-badge">{t}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Agent System -->
    <section class="lab-section">
      <h2 class="section-heading">Agent System</h2>
      <p class="section-desc">Specialized Claude Code agents with automatic routing. Each agent owns a domain and follows operational contracts.</p>
      <div class="agent-groups">
        {agentGroups.map((group) => (
          <div class="agent-group">
            <h3 class="group-label" style={`border-color: ${group.color}`}>{group.label}</h3>
            <div class="agent-list">
              {group.agents.map((a) => (
                <div class="agent-item">
                  <span class="agent-name" style={`color: ${group.color}`}>{a.name}</span>
                  <span class="agent-role">{a.role}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Apps -->
    <section class="lab-section">
      <h2 class="section-heading">Apps and Tools</h2>
      <p class="section-desc">Self-hosted applications built and deployed from the terminal.</p>
      <div class="card-grid">
        {apps.map((a) => (
          <div class="card">
            <div class="card-header">
              <h3 class="card-title">{a.name}</h3>
              {a.url && (
                <a href={a.url} target="_blank" rel="noopener" class="card-gh" title="GitHub">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                </a>
              )}
            </div>
            <p class="card-desc">{a.desc}</p>
            <div class="card-tech">
              {a.tech.map((t) => (
                <span class="tech-badge">{t}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- How It's Built -->
    <section class="lab-section">
      <h2 class="section-heading">How It's Built</h2>
      <p class="section-desc">Patterns and approaches behind the system.</p>
      <div class="techniques">
        {techniques.map((t) => (
          <div class="technique">
            <h3 class="technique-title">{t.title}</h3>
            <p class="technique-desc">{t.desc}</p>
            {t.post && (
              <a href={t.post} class="technique-link">Read the build log &rarr;</a>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Footer -->
    <footer class="lab-footer">
      <p>&copy; {new Date().getFullYear()} Your Name</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .lab-container { max-width: 720px; margin: 0 auto; padding: 2rem 1rem; }

  .lab-hero { text-align: center; padding: 1.5rem 0 2rem; }
  .lab-title { font-size: 2.25rem; font-weight: 900; letter-spacing: -0.03em; background: linear-gradient(135deg, var(--orange), var(--blue)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .lab-tagline { display: flex; align-items: center; justify-content: center; gap: 0.5rem; font-size: 0.85rem; color: var(--text-muted); font-weight: 500; margin-top: 0.25rem; letter-spacing: 0.01em; }
  .lab-avatar { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; border: 2px solid var(--border-color); }
  .lab-links { display: flex; justify-content: center; gap: 1.25rem; margin-top: 0.5rem; }
  .lab-social { display: flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
  .lab-social:hover { color: var(--orange); }
  .lab-divider { width: 40px; height: 3px; background: linear-gradient(90deg, var(--orange), var(--blue)); border-radius: 2px; margin: 1rem auto 1.25rem; }
  .lab-intro { text-align: left; max-width: 620px; margin: 0 auto; }
  .lab-intro p { font-size: 0.9rem; line-height: 1.7; color: var(--text-secondary); }
  .lab-intro p + p { margin-top: 0.75rem; }
  .lab-intro p:last-child { font-weight: 600; color: var(--text-primary); font-size: 0.85rem; }

  .lab-section { padding: 2rem 0; border-top: 1px solid var(--border-color); }
  .section-heading { font-size: 1.1rem; font-weight: 700; color: var(--orange); margin-bottom: 0.35rem; }
  .section-desc { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.25rem; line-height: 1.5; }

  .card-featured { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 0.75rem; border-left: 3px solid var(--orange); transition: border-color 0.2s; }
  .card-featured .card-title { font-size: 1rem; }
  .card-featured .card-desc { font-size: 0.85rem; }

  .card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem; display: flex; flex-direction: column; gap: 0.5rem; transition: border-color 0.2s; }
  .card:hover { border-color: var(--orange); }
  .card-header { display: flex; justify-content: space-between; align-items: center; }
  .card-title { font-size: 0.9rem; font-weight: 700; color: var(--text-primary); }
  .card-gh { color: var(--text-muted); transition: color 0.2s; flex-shrink: 0; }
  .card-gh:hover { color: var(--orange); }
  .card-desc { font-size: 0.8rem; line-height: 1.5; color: var(--text-secondary); }
  .card-tech { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: auto; }
  .tech-badge { font-size: 0.65rem; font-weight: 600; padding: 0.1rem 0.45rem; border-radius: 3px; background: rgba(26, 111, 181, 0.12); color: var(--blue-light); text-transform: uppercase; letter-spacing: 0.04em; }

  .agent-groups { display: flex; flex-direction: column; gap: 1.25rem; }
  .agent-group { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem; }
  .group-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding-bottom: 0.5rem; margin-bottom: 0.65rem; border-bottom: 2px solid; }
  .agent-list { display: flex; flex-direction: column; gap: 0.4rem; }
  .agent-item { display: flex; gap: 0.6rem; align-items: baseline; font-size: 0.82rem; line-height: 1.4; }
  .agent-name { font-weight: 700; flex-shrink: 0; min-width: 80px; }
  .agent-role { color: var(--text-secondary); }

  .techniques { display: flex; flex-direction: column; gap: 0.75rem; }
  .technique { background: var(--bg-card); border: 1px solid var(--border-color); border-left: 3px solid var(--orange); border-radius: 8px; padding: 0.85rem 1rem; }
  .technique-title { font-size: 0.85rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.25rem; }
  .technique-desc { font-size: 0.8rem; line-height: 1.5; color: var(--text-secondary); }
  .technique-link { display: inline-block; margin-top: 0.4rem; font-size: 0.75rem; font-weight: 600; color: var(--orange); transition: color 0.2s; }
  .technique-link:hover { color: var(--orange-light); }

  .lab-footer { padding-top: 2rem; margin-top: 1rem; border-top: 1px solid var(--border-color); text-align: center; }
  .lab-footer p { font-size: 0.8rem; color: var(--text-muted); }

  @media (max-width: 640px) {
    .card-grid { grid-template-columns: 1fr; }
    .lab-container { padding: 1rem 0.75rem; }
    .lab-title { font-size: 1.75rem; }
    .agent-item { flex-direction: column; gap: 0.1rem; }
    .agent-name { min-width: unset; }
  }
</style>
