---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Markdown from '../components/Markdown.astro';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('posts');
  const sorted = allPosts.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
  return paginate(sorted, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const posts = page.data;

const allPosts = await getCollection('posts');
const tagCounts: Record<string, number> = {};
allPosts.forEach((post) => {
  post.data.tags?.forEach((tag: string) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});
const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout>
  <div class="feed-container">
    <header class="feed-header">
      <!-- Hero: Replace with your name, photo, and links -->
      <div class="hero">
        <a href="/" class="avatar-ring">
          <img src="/images/avatar.svg" alt="Your Name" class="avatar" />
        </a>
        <h1 class="profile-name">Your Name</h1>
        <div class="profile-links">
          <!-- GitHub -->
          <a href="https://github.com/your-username" target="_blank" rel="noopener" class="social-link" title="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <!-- LinkedIn -->
          <a href="https://linkedin.com/in/your-profile" target="_blank" rel="noopener" class="social-link" title="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <!-- Email -->
          <a href="mailto:you@example.com" class="social-link" title="Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
          </a>
          <!-- RSS -->
          <a href="/rss.xml" class="social-link" title="RSS Feed">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795 0 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.742-7.115-15.793-15.839-15.82zm0-8.18v4.819c12.951.115 23.424 10.574 23.5 23.501h4.5c-.076-15.673-12.792-28.365-28-28.32z"/></svg>
          </a>
        </div>
        <div class="name-banner">
          <a href="https://yoursite.com">yoursite.com</a>
        </div>
      </div>

      <!-- Bio: Replace with your description and skill pills -->
      <div class="info-card info-card-full">
        <p class="about-bio">Builder, maker, and tinkerer. I use Claude Code to ship projects and document what I learn along the way.</p>
        <div class="about-pills">
          <span class="about-pill">Claude Code</span>
          <span class="about-pill">Astro</span>
          <span class="about-pill">Your Skill</span>
          <span class="about-pill">Another Skill</span>
        </div>
        <p class="info-location">Your City, ST</p>
      </div>

      <!-- What is The Stack -->
      <div class="info-card info-how-it-works">
        <h3 class="info-card-title">What Is The Stack?</h3>
        <div class="info-card-divider"></div>
        <p>A build log. Notes on what I'm shipping, learning, and figuring out. No CMS, no dashboard. Every post is published straight from the terminal with a single command.</p>
        <a href="/post/003-how-this-works/" class="how-link">How it's built &rarr;</a>
        <div class="header-tags">
          {sortedTags.slice(0, 10).map(([tag, count]) => (
            <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="header-tag">{tag} <span class="tag-count">{count}</span></a>
          ))}
        </div>
      </div>
    </header>

    <div class="feed">
      {posts.map((post) => {
        const date = new Date(post.data.date);
        const y = date.getFullYear();
        const m = String(date.getMonth() + 1).padStart(2, '0');
        const d = String(date.getDate()).padStart(2, '0');
        const timeDisplay = `${y}.${m}.${d}`;

        const isPinned = post.data.tags?.includes('Pinned');

        return (
          <article id={post.id} class={`post ${isPinned ? 'post-pinned' : ''}`}>
            <div class="post-header">
              <img src="/images/avatar.svg" alt="" class="post-avatar" />
              <div>
                <span class="post-author">You</span>
                <span class="post-date">{timeDisplay}</span>
              </div>
            </div>
            <div class={`post-body ${post.data.text.length > 400 && !isPinned ? 'post-truncated' : ''}`}>
              <div class="post-content">
                <Markdown text={post.data.text} />
              </div>
              {post.data.text.length > 400 && !isPinned && (
                <button class="expand-btn">Show more</button>
              )}
              {post.data.image && (
                <img src={post.data.image} alt="" class="post-image" loading="lazy" />
              )}
              {post.data.link && (
                <a href={post.data.link} class="post-link" target="_blank" rel="noopener">
                  {post.data.link.replace('https://', '')} ↗
                </a>
              )}
            </div>
            <div class="post-footer">
              {post.data.tags && (
                <div class="post-tags">
                  {post.data.tags.map((tag: string) => (
                    <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="tag">{tag}</a>
                  ))}
                </div>
              )}
              {!isPinned && (
                <div class="post-actions">
                  <button class="share-btn" data-url={`${Astro.site}#${post.id}`} title="Copy link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                  </button>
                </div>
              )}
            </div>
          </article>
        );
      })}
    </div>

    {page.lastPage > 1 && (
      <nav class="pagination">
        {page.url.prev ? (
          <a href={page.url.prev} class="page-link">&larr; Newer</a>
        ) : (
          <span class="page-link disabled">&larr; Newer</span>
        )}
        <span class="page-info">{page.currentPage} / {page.lastPage}</span>
        {page.url.next ? (
          <a href={page.url.next} class="page-link">Older &rarr;</a>
        ) : (
          <span class="page-link disabled">Older &rarr;</span>
        )}
      </nav>
    )}

    <footer class="feed-footer">
      <p>&copy; {new Date().getFullYear()} Your Name</p>
    </footer>
  </div>
  <script>
    document.querySelectorAll('.share-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const url = (btn as HTMLElement).dataset.url;
        if (url) {
          await navigator.clipboard.writeText(url);
          const el = btn as HTMLElement;
          el.style.color = 'var(--orange)';
          setTimeout(() => { el.style.color = ''; }, 1500);
        }
      });
    });

    document.querySelectorAll('.expand-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const postBody = btn.closest('.post-body');
        if (postBody) {
          postBody.classList.toggle('post-truncated');
          (btn as HTMLElement).textContent = postBody.classList.contains('post-truncated') ? 'Show more' : 'Show less';
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .feed-container {
    max-width: 640px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .feed-header {
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 0.5rem;
  }

  .header-tags {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .header-tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: rgba(26, 111, 181, 0.08);
    color: var(--text-muted);
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }

  .header-tag:hover {
    background: rgba(26, 111, 181, 0.2);
    color: var(--blue-light);
  }

  .tag-count {
    color: var(--blue-light);
    font-weight: 700;
  }

  /* Hero */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem 0 1.25rem;
  }

  .avatar-ring {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    padding: 4px;
    background: linear-gradient(135deg, var(--orange), var(--blue));
    margin-bottom: 1rem;
  }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--bg-primary);
  }

  .profile-name {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 0.15rem;
  }

  .name-banner {
    margin-top: 0.5rem;
    padding: 0.35rem 1.25rem;
    background: linear-gradient(135deg, var(--orange), var(--blue));
    border-radius: 6px;
  }

  .name-banner a {
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-decoration: none;
  }

  .info-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .info-card-title {
    font-size: 1rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .info-card-divider {
    width: 40px;
    height: 3px;
    background: linear-gradient(90deg, var(--orange), var(--blue));
    border-radius: 2px;
    margin-bottom: 0.75rem;
  }

  .info-card-full {
    margin-top: 1.25rem;
    text-align: center;
  }

  .info-how-it-works {
    margin-top: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.25rem;
    border-left: 3px solid var(--orange);
  }

  .info-how-it-works p {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .how-link {
    display: inline-block;
    margin-top: 0.6rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--orange);
    text-decoration: none;
    transition: color 0.2s;
  }

  .how-link:hover {
    color: var(--blue-light);
  }

  .info-how-it-works .header-tags {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-color);
  }

  .about-bio {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .about-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .about-pill {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(232, 145, 62, 0.12), rgba(26, 111, 181, 0.12));
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .info-card p {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .info-location {
    margin-top: 0.6rem;
    font-size: 0.78rem !important;
    color: var(--text-muted) !important;
    letter-spacing: 0.03em;
  }

  .feed {
    display: flex;
    flex-direction: column;
  }

  .post {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .post:last-child {
    border-bottom: none;
  }

  .post-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .post-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
  }

  .post-author {
    font-weight: 600;
    font-size: 0.9rem;
    display: block;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .post-body p,
  .post-body :global(.markdown-body p) {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .post-body :global(.markdown-body p + p) {
    margin-top: 0.75rem;
  }

  .post-body :global(.markdown-body strong) {
    color: var(--text-primary);
    font-weight: 700;
  }

  .post-body :global(.markdown-body ol),
  .post-body :global(.markdown-body ul) {
    margin: 0.5rem 0 0.5rem 1.25rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .post-body :global(.markdown-body li + li) {
    margin-top: 0.35rem;
  }

  .post-body :global(.markdown-body code) {
    font-size: 0.85rem;
    background: var(--bg-card);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    border: 1px solid var(--border-color);
  }

  .post-body :global(.markdown-body h4) {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 1rem;
    margin-bottom: 0.25rem;
  }

  .post-image {
    max-width: 280px;
    height: auto;
    border-radius: 8px;
    margin-top: 0.75rem;
    border: 1px solid var(--border-color);
    opacity: 0.85;
    transition: opacity 0.2s;
  }

  .post-image:hover {
    opacity: 1;
  }

  .post-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .post-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.75rem;
  }

  .post-actions {
    display: flex;
    gap: 0.5rem;
  }

  .share-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.25rem;
    transition: color 0.2s;
  }

  .share-btn:hover {
    color: var(--orange);
  }

  .profile-links {
    display: flex;
    gap: 1rem;
    margin-top: 0.35rem;
  }

  .social-link {
    color: var(--text-muted);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .social-link:hover {
    color: var(--orange);
  }

  .post-truncated .post-content {
    max-height: 6.5em;
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
  }

  .expand-btn {
    background: none;
    border: none;
    color: var(--orange);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    padding: 0.25rem 0;
    margin-top: 0.25rem;
    transition: color 0.2s;
  }

  .expand-btn:hover {
    color: var(--orange-light);
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: rgba(26, 111, 181, 0.12);
    color: var(--blue-light);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: background 0.2s;
  }

  .post-pinned {
    background: var(--bg-card);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 0.5rem;
    border: 1px solid var(--border-color);
    border-left: 3px solid var(--orange);
  }

  .post-pinned .post-date {
    color: var(--orange);
    font-weight: 600;
  }

  .tag:hover {
    background: rgba(26, 111, 181, 0.25);
    color: var(--blue-light);
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    margin-top: 1rem;
    border-top: 1px solid var(--border-color);
  }

  .page-link {
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--blue-light);
    transition: color 0.2s;
  }

  .page-link:hover {
    color: var(--orange);
  }

  .page-link.disabled {
    color: var(--text-muted);
    opacity: 0.4;
  }

  .page-info {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .feed-footer {
    padding-top: 2rem;
    margin-top: 1rem;
    border-top: 1px solid var(--border-color);
    text-align: center;
  }

  .feed-footer p {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  @media (max-width: 480px) {
    .feed-container {
      padding: 1rem 0.75rem;
    }

    .avatar-ring {
      width: 100px;
      height: 100px;
    }

    .profile-name {
      font-size: 1.5rem;
    }
  }
</style>
