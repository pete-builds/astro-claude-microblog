---
import { marked } from 'marked';

interface Props {
  text: string;
}

const { text } = Astro.props;

marked.use({
  renderer: {
    html(token) {
      return token.text
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    },
  },
});

const html = await marked.parse(text, { breaks: true });
---

<div class="markdown-body" set:html={html} />
