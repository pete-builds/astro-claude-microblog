---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'The Stack | Your Name',
  description = 'A build log. Notes on what I ship, learn, and figure out.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <!-- Replace with a 1200x630 PNG or JPG for social sharing -->
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Add your analytics here -->

    <link rel="alternate" type="application/rss+xml" title="The Stack RSS" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="site-nav">
      <a href="/feed/" class="nav-link">Build Log</a>
      <span class="nav-sep">/</span>
      <a href="/" class="nav-link">CV</a>
    </nav>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-primary: #141416;
    --bg-secondary: #1a1a1e;
    --bg-card: #1e1e22;
    --text-primary: #e8e8e8;
    --text-secondary: #a0a0a8;
    --text-muted: #6b6b75;
    --orange: #e87722;
    --orange-light: #f09050;
    --blue: #1a6fb5;
    --blue-light: #4a9fd8;
    --border-color: #2a2a30;
    --card-radius: 16px;
    --transition: 0.2s ease;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .site-nav { display: flex; justify-content: center; gap: 0.5rem; padding: 0.75rem 1rem 0; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.03em; }
  .nav-link { color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
  .nav-link:hover { color: var(--orange); }
  .nav-sep { color: var(--border-color); }

  a { color: var(--orange); text-decoration: none; transition: color var(--transition); }
  a:hover { color: var(--orange-light); }

  /* Shared post styles */
  .feed { display: flex; flex-direction: column; }
  .post { padding: 1.5rem 0; border-bottom: 1px solid var(--border-color); }
  .post:last-child { border-bottom: none; }
  .post-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
  .post-avatar { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; }
  .post-author { font-weight: 600; font-size: 0.9rem; display: block; }
  .post-date { font-size: 0.8rem; color: var(--text-muted); }
  .post-body p, .post-body .markdown-body p { font-size: 0.95rem; line-height: 1.7; color: var(--text-secondary); }
  .post-body .markdown-body p + p { margin-top: 0.75rem; }
  .post-body .markdown-body strong { color: var(--text-primary); font-weight: 700; }
  .post-body .markdown-body ol, .post-body .markdown-body ul { margin: 0.5rem 0 0.5rem 1.25rem; font-size: 0.95rem; line-height: 1.7; color: var(--text-secondary); }
  .post-body .markdown-body li + li { margin-top: 0.35rem; }
  .post-body .markdown-body code { font-size: 0.85rem; background: var(--bg-card); padding: 0.1rem 0.35rem; border-radius: 3px; border: 1px solid var(--border-color); }
  .post-body .markdown-body h4 { font-size: 0.9rem; font-weight: 700; color: var(--text-primary); margin-top: 1rem; margin-bottom: 0.25rem; }
  .post-image { max-width: 280px; height: auto; border-radius: 8px; margin-top: 0.75rem; border: 1px solid var(--border-color); opacity: 0.85; transition: opacity 0.2s; }
  .post-image:hover { opacity: 1; }
  .post-link { display: inline-block; margin-top: 0.75rem; font-size: 0.85rem; font-weight: 500; }
  .post-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 0.75rem; }
  .post-tags { display: flex; gap: 0.4rem; }
  .tag { font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 4px; background: rgba(26, 111, 181, 0.12); color: var(--blue-light); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; text-decoration: none; transition: background 0.2s; }
  .tag:hover { background: rgba(26, 111, 181, 0.25); color: var(--blue-light); }
  .post-pinned { background: var(--bg-card); border-radius: 12px; padding: 1.5rem; margin-bottom: 0.5rem; border: 1px solid var(--border-color); border-left: 3px solid var(--orange); }
  .post-pinned .post-date { color: var(--orange); font-weight: 600; }
  .post-actions { display: flex; gap: 0.5rem; }
  .share-btn { background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 0.25rem; transition: color 0.2s; }
  .share-btn:hover { color: var(--orange); }
  .post-truncated .post-content { max-height: 6.5em; overflow: hidden; position: relative; mask-image: linear-gradient(to bottom, black 60%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%); }
  .expand-btn { background: none; border: none; color: var(--orange); font-size: 0.85rem; font-weight: 600; cursor: pointer; padding: 0.25rem 0; margin-top: 0.25rem; transition: color 0.2s; }
  .expand-btn:hover { color: var(--orange-light); }

  /* Shared layout */
  .feed-container { max-width: 640px; margin: 0 auto; padding: 2rem 1rem; }
  .feed-header { padding-bottom: 2rem; border-bottom: 1px solid var(--border-color); margin-bottom: 1.5rem; }
  .profile { display: flex; gap: 1.25rem; align-items: center; }
  .avatar { width: 80px; height: 80px; border-radius: 50%; border: 2px solid var(--border-color); object-fit: cover; }
  .profile-info h1 { font-size: 1.5rem; font-weight: 900; letter-spacing: -0.02em; background: linear-gradient(135deg, var(--orange), var(--blue)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .profile-bio { font-size: 0.95rem; color: var(--text-secondary); margin-top: 0.25rem; }
  .profile-location { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem; }
  .profile-links { display: flex; gap: 0.75rem; margin-top: 0.5rem; }
  .social-link { color: var(--text-muted); transition: color 0.2s; }
  .social-link:hover { color: var(--orange); }
  .current-tag { color: var(--orange); font-weight: 600; }
  .feed-footer { padding-top: 2rem; margin-top: 1rem; border-top: 1px solid var(--border-color); text-align: center; }
  .feed-footer p { font-size: 0.8rem; color: var(--text-muted); }

  @media (max-width: 480px) {
    .profile { flex-direction: column; text-align: center; }
    .feed-container { padding: 1rem 0.75rem; }
    .profile-links { justify-content: center; }
  }
</style>
